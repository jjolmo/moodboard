{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"fs:default",
		"fs:allow-read-file",
		"fs:allow-write-file",
		"fs:allow-exists",
		"fs:allow-mkdir",
		"fs:allow-remove",
		"fs:allow-rename",
		"fs:allow-read-dir",
		"dialog:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"clipboard-manager:allow-read-image",
		"clipboard-manager:allow-read-text",
		{
			"identifier": "fs:scope",
			"allow": [
				{ "path": "$APPDATA/**" },
				{ "path": "$HOME/**" },
				{ "path": "$DOWNLOAD/**" },
				{ "path": "$DESKTOP/**" }
			]
		}
	]
}
