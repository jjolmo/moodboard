{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "Simple Moodboard",
	"version": "0.2.0",
	"identifier": "com.simplemoodboard.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run kill-port; npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "Simple Moodboard",
				"width": 1280,
				"height": 800,
				"minWidth": 900,
				"minHeight": 600,
				"decorations": true,
				"backgroundColor": "#f5f5f5"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1MEY0MDk4NzM5QjZBRTYKUldUbWFwdHptRUFQcFFMQnZYTnl6NXRpb3FWWUlmRkdnVENycGd0LzVMektQeVA4U2xoMTJjRnQK",
			"endpoints": [
				"https://github.com/jjolmo/moodboard/releases/latest/download/latest.json"
			]
		}
	}

}
